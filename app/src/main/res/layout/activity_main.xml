<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?android:attr/colorBackground"
    tools:context=".ReportActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Colored header band ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_header_band"
            android:paddingTop="40dp"
            android:paddingBottom="24dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_traffic_alert"
                android:contentDescription="@string/header_icon_desc"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_text"
                android:textAppearance="?attr/textAppearanceHeadlineSmall"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ── Report type ─────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/label_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_type"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <!-- Outlined card wrapping the Spinner for consistent styling -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="52dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutline"
                app:cardBackgroundColor="?attr/colorSurface">

                <Spinner
                    android:id="@+id/spinner_report_type"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:entries="@array/traffic_types"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ── Description ────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/label_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_description"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:textColor="?attr/colorOnSurface"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_layout_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_text_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_description"
                    android:inputType="textCapSentences|textMultiLine"
                    android:minHeight="100dp"
                    android:maxLines="5" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- ── Severity ───────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Label row: "Severity Level" label + live chip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/label_severity"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_severity"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="?attr/colorOnSurface"
                    android:textStyle="bold" />

                <!-- Live severity chip: color updated at runtime by ReportActivity -->
                <TextView
                    android:id="@+id/text_severity_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_severity_chip"
                    android:textAppearance="?attr/textAppearanceLabelLarge"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Scale labels: Low / Medium / High -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/severity_label_low"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/severity_low"
                    android:gravity="start" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/severity_label_medium"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/severity_medium"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/severity_label_high"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="@color/severity_high"
                    android:gravity="end" />

            </LinearLayout>

            <!-- SeekBar -->
            <SeekBar
                android:id="@+id/seek_bar_severity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:min="1"
                android:max="5"
                android:progress="1"
                android:thumbTint="?attr/colorPrimary"
                android:progressTint="?attr/colorPrimary"
                android:progressBackgroundTint="?attr/colorOutlineVariant" />

        </LinearLayout>

        <!-- ── Submit button ──────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="32dp">

            <Button
                android:id="@+id/button_submit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/button_submit"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textAppearance="?attr/textAppearanceLabelLarge"
                android:elevation="4dp"
                app:backgroundTint="?attr/colorPrimary"
                app:cornerRadius="28dp"
                android:textColor="?attr/colorOnPrimary" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
